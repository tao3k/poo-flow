(package: poo-flow
 depend: ("git.cons.io/mighty-gerbils/gerbil-poo"
          "github.com/tao3k/gerbil-scheme-language-project-harness")
 policy: ((macro-governance
           allow-generated: #t
           explanation: "Agent-sandbox backend profile macros must cite runtime-source guidance and expansion tests before changing transformer behavior."
          witness: "search runtime-source macro sugar module-sugar; t/agent-sandbox-profile-test.ss witnesses generated descriptor/profile constructors")
          (source-scope
           roots: ("src" "user-interface")
           runtime-roots: (".")
           explanation: "The Gerbil language project harness covers source owners under src, user-interface, and the default t test root; root generated files such as manifest.ss are not source owners.")
          (runtime-boundary
           heavy-owners: ("rust" "external-runtime")
           explanation: "CAS, Docker, subprocesses, parallel scheduling, and durable persistence are not Scheme-owned.")
          (poo-control-plane
           explanation: "Flow, task, strategy, runner, adapter, and receipt objects form the first Gerbil POO surface.")))

#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")/.."

: "${CC:=cc}"

extra_args=""
if "$CC" --version 2>/dev/null | grep -qi clang; then
  extra_args="-Qunused-arguments"
fi

exec "$CC" \
  $extra_args \
  -std=c11 \
  -Wall \
  -Wextra \
  -Werror \
  -fsyntax-only \
  -Ibindings/nono-c \
  -I.data/nono/bindings/c/include \
  bindings/nono-c/poo_flow_nono_binding_probe.c
